# Copy this file to ".env" and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# OPTIONAL: enables the "Unsplash" tab in the Mood board.
# Get a free Access Key at https://unsplash.com/developers (create an app).
# Leave blank to hide the feature.
VITE_UNSPLASH_KEY=
