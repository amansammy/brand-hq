# Copy this file to ".env" and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# OPTIONAL: enables the "Unsplash" tab in the Mood board.
# Get a free Access Key at https://unsplash.com/developers (create an app).
# Leave blank to hide the feature.
VITE_UNSPLASH_KEY=

# OPTIONAL: powers the AI Design Studio via Cloudflare Workers AI (free tier).
# These are SERVER-SIDE only (no VITE_ prefix) — set them in Vercel, not here, so
# they never reach the browser. Get them free at dash.cloudflare.com:
#   CF_ACCOUNT_ID = Account ID (right sidebar of the dashboard)
#   CF_API_TOKEN  = a token with the "Workers AI" + "Account Analytics:Read" permissions
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
